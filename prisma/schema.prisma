// =====================================================
// IDENTITY SERVICE - PRISMA SCHEMA
// User Management, Authentication & Authorization
// =====================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ENUMS
// =====================================================

enum Role {
  GUEST
  USER
  OWNER
  ADMIN
  SUPER_ADMIN
}

enum AccountType {
  EMAIL
  PHONE
  GOOGLE
  APPLE
  FACEBOOK
  WHATSAPP
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

// =====================================================
// MODELS
// =====================================================

// User Model - Core identity
model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  fullName      String?
  displayName  String?
  avatarUrl    String?
  bio          String?
  
  // Role-based access
  role          Role      @default(USER)
  
  // Status
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  isShadowBanned Boolean   @default(false) // Shadow ban - hides user's reviews publicly
  emailVerified DateTime?
  phoneVerified DateTime?
  
  // Profile fields
  dateOfBirth   DateTime?
  gender        String?
  city          String?
  country       String?
  
  // Trust Score (0-100)
  trustScore    Int       @default(50)
  
  // Preferences
  preferences   Json      @default("{}")
  settings      Json      @default("{}")
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?

  // Relations
  accounts      Account[]
  sessions      Session[]
  venues        Venue[]   @relation("OwnerVenues")
  
  // Social connections
  friends       Friendship[]     @relation("UserFriends")
  friendOf      Friendship[]     @relation("FriendOf")
  
  // Activity
  vibeChecks    VibeCheck[]
  bookings      Booking[]
  wallet        Wallet?
  
  @@index([email])
  @@index([phone])
  @@index([role])
}

// Account Model - OAuth & credential providers
model Account {
  id                String      @id @default(cuid())
  userId            String
  type              AccountType
  provider          String
  providerAccountId String
  
  // OAuth fields
  refresh_token     String?     @db.Text
  access_token      String?     @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?     @db.Text
  session_state     String?
  
  // Credentials (for email/password)
  passwordHash      String?
  
  // Status
  isActive          Boolean     @default(true)
  
  // Timestamps
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  
  // Relation
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Constraints
  @@unique([provider, providerAccountId])
  @@unique([userId, type])
  @@index([userId])
}

// Session Model - Active user sessions
model Session {
  id            String        @id @default(cuid())
  sessionToken  String        @unique
  userId        String
  expiresAt     DateTime
  status        SessionStatus @default(ACTIVE)
  
  // Device info
  userAgent     String?
  ipAddress     String?
  deviceType    String?
  location      String?
  
  // Timestamps
  createdAt     DateTime      @default(now())
  lastActiveAt  DateTime      @default(now())
  
  // Relation
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
  @@index([status])
}

// Verification Token Model - Email/phone verification
model VerificationToken {
  identifier  String
  token      String      @unique
  expires    DateTime
  
  @@unique([identifier, token])
  @@index([expires])
}

// =====================================================
// VENUE (Partial - for owner relation)
// =====================================================

model Venue {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  address     String?
  city        String?
  ownerId     String?
  
  // Location (PostGIS geography point - using raw SQL for queries)
  latitude    Float?
  longitude   Float?
  
  // Tagging System
  musicGenres String[]  @default([])
  vibes       String[]  @default([])
  facilities  String[]  @default([])
  
  // Category
  category    String?   @default("nightclub")
  
  // Status
  isActive    Boolean  @default(true)
  isVerified  Boolean  @default(false)
  isBoosted   Boolean  @default(false)
  boostExpiry DateTime?
  
  // Trust Score (calculated from verified reviews)
  trustScore  Float    @default(50.0)
  
  // Rating Aggregates (updated via trigger)
  averageRating Float  @default(0.0)
  totalReviews  Int    @default(0)
  
  // Gallery
  galleryImages String[] @default([])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  owner       User?    @relation("OwnerVenues", fields: [ownerId], references: [id])
  
  // References from other schemas
  vibeChecks  VibeCheck[]
  bookings    Booking[]
  promos      Promo[]
}

// =====================================================
// ADDITIONAL MODELS (from existing schema)
// =====================================================

model VibeCheck {
  id                    String   @id @default(cuid())
  venueId               String
  userId                String?
  rating                Int
  comment               String?
  receiptImageUrl       String?
  aiVerificationConfidence Float?
  isVerifiedPurchase    Boolean  @default(false)
  
  // GPS Verification
  gpsStatus             String   @default("PENDING")  // MATCH, MISMATCH, PENDING
  isEliteVerified       Boolean  @default(false)     // Struk + GPS verified
  userLatitude          Float?
  userLongitude         Float?
  isVerifiedVisit       Boolean  @default(false)     // GPS verified only
  
  // Social Interactions
  likesCount            Int      @default(0)
  reportsCount          Int      @default(0)
  isFlaggedForReview   Boolean  @default(false)     // Auto-flagged for high reports
  
  // Rejection tracking
  isApproved            Boolean  @default(false)
  rejectionReasonCode   String?  // Code: FAKE_REVIEW, INAPPROPRIATE, SPAM, POLICY_VIOLATION
  rejectionReason       String?  // Human-readable reason
  reviewedBy            String?  // Admin user ID who reviewed
  reviewedAt            DateTime?
  
  createdAt             DateTime @default(now())
  
  venue                 Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user                  User?    @relation(fields: [userId], references: [id])
  likes                 ReviewLike[]
  reports               ReviewReport[]
}

// =====================================================
// SOCIAL INTERACTION MODELS
// =====================================================

model ReviewLike {
  id          String    @id @default(cuid())
  reviewId    String
  userId      String
  createdAt   DateTime  @default(now())
  
  review      VibeCheck @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  
  @@unique([reviewId, userId]) // One like per user per review
  @@index([reviewId])
  @@index([userId])
}

model ReviewReport {
  id          String    @id @default(cuid())
  reviewId    String
  userId      String
  reason      String    // FAKE, SPAM, INAPPROPRIATE, etc.
  description String?
  status      String    @default("pending") // pending, reviewed, resolved
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  
  review      VibeCheck @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  
  @@index([reviewId])
  @@index([userId])
  @@index([status])
}

model Booking {
  id            String   @id @default(cuid())
  venueId       String
  userId        String?
  guestName     String
  guestPhone    String
  guestEmail    String?
  date          DateTime
  time          String
  pax           Int
  status        String   @default("pending")
  totalAmount   Float?
  notes         String?
  createdAt     DateTime @default(now())
  
  // Extended Reservation Fields
  tableType     String?   // REGULAR, VIP, ROYAL, BOOTH
  tableNumber   String?
  depositAmount Float?
  depositPaid   Boolean  @default(false)
  specialRequests String?
  confirmationCode String? @unique
  
  // Timestamps
  confirmedAt   DateTime?
  cancelledAt   DateTime?
  completedAt   DateTime?
  
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user          User?    @relation(fields: [userId], references: [id])
  
  @@index([venueId])
  @@index([userId])
  @@index([status])
  @@index([date, time])
}

model Promo {
  id          String   @id @default(cuid())
  venueId     String
  title       String
  description String?
  discountType String
  discountValue Float?
  priceValue  Float?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  targetCategory String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  
  venue       Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

// =====================================================
// ADVERTISEMENT & PAYMENT MODELS
// =====================================================

model AdSlot {
  id            String    @id @default(cuid())
  venueId       String
  
  // Slot Configuration
  slotType      String    // HERO, BANNER, SPONSORED, FEATURED
  startDate     DateTime
  endDate       DateTime
  
  // Status
  isActive      Boolean   @default(false)
  isPaid        Boolean   @default(false)
  
  // Pricing
  priceAmount   Float
  currency      String    @default("IDR")
  
  // Timestamps
  createdAt     DateTime  @default(now())
  paidAt        DateTime?
  
  // Relations
  venue         Venue     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  payment       Payment?
  
  @@index([venueId])
  @@index([isActive])
  @@index([startDate, endDate])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SETTLED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  E_WALLET
  GOPAY
  OVO
  DANA
  SHOPEEPAY
  QRIS
}

model Payment {
  id              String        @id @default(cuid())
  adSlotId        String        @unique
  
  // Payment Details
  amount          Float
  currency        String        @default("IDR")
  method          PaymentMethod?
  status          PaymentStatus  @default(PENDING)
  
  // Gateway Reference
  transactionId   String?       @unique  // Midtrans/Xendit transaction ID
  orderId         String?        @unique
  
  // Payment Info
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  
  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  settledAt       DateTime?
  expiredAt       DateTime?
  
  // Webhook Data
  webhookPayload  Json?
  
  // Relations
  adSlot          AdSlot       @relation(fields: [adSlotId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([transactionId])
  @@index([createdAt])
}

model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Float    @default(0)
  points      Int      @default(0)
  tier        String   @default("bronze")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  
  user      User     @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
  
  @@unique([userId, friendId])
}

// =====================================================
// GAMIFICATION & LOYALTY MODELS
// =====================================================

model UserGamification {
  id              String   @id @default(cuid())
  userId          String   @unique
  
  // XP & Level
  currentXp       Int      @default(0)
  totalXp         Int      @default(0)
  currentLevel    Int      @default(1)
  
  // Streaks
  streakDays      Int      @default(0)
  longestStreak  Int      @default(0)
  lastActivityAt DateTime?
  
  // Statistics
  totalReviews    Int      @default(0)
  totalVisits     Int      @default(0)
  totalCheckIns   Int      @default(0)
  venuesVisited   String[] @default([]) // Array of venue IDs
  
  // Referral
  referralCode    String   @unique
  referredBy      String?
  referralCount   Int      @default(0)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([currentXp])
  @@index([currentLevel])
}

// Badge/Achievement Types
enum BadgeType {
  MILESTONE    // First drink, city explorer, etc
  ELITE        // Elite reviewer, VIP, etc
  SEASONAL     // Holiday special badges
  Hidden       // Secret/easter egg badges
}

model Badge {
  id            String     @id @default(cuid())
  code          String     @unique  // e.g., "FIRST_DRINK", "CITY_EXPLORER"
  name          String
  description   String
  icon          String?    // Icon identifier
  badgeType     BadgeType  @default(MILESTONE)
  
  // Requirements
  requirementType String?  // REVIEW_COUNT, VISIT_COUNT, STREAK, etc
  requirementValue Int?     // Number needed
  
  // Rewards
  xpReward      Int        @default(0)
  
  // Display
  tier          String     @default("bronze") // bronze, silver, gold, platinum
  isHidden      Boolean    @default(false)
  
  createdAt     DateTime   @default(now())
  
  userBadges    UserBadge[]
  
  @@index([badgeType])
  @@index([tier])
}

model UserBadge {
  id          String   @id @default(cuid())
  userId      String
  badgeId     String
  earnedAt    DateTime @default(now())
  
  user        UserGamification @relation(fields: [userId], references: [userId], onDelete: Cascade)
  badge       Badge   @relation(fields: [badgeId], references: [id])
  
  @@unique([userId, badgeId])
  @@index([userId])
}

// Daily Missions
enum MissionStatus {
  AVAILABLE
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

model Mission {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  description   String
  
  // Requirements
  missionType    String       // CHECK_IN, REVIEW, VISIT_VENUE, etc
  targetCount    Int          @default(1)
  targetVenueCategory String?
  
  // Rewards
  xpReward      Int          @default(10)
  isDoubleXp    Boolean      @default(false)
  
  // Timing
  isDaily       Boolean      @default(true)
  isActive      Boolean      @default(true)
  startDate     DateTime?
  endDate       DateTime?
  
  createdAt     DateTime     @default(now())
  
  userMissions UserMission[]
}

model UserMission {
  id          String       @id @default(cuid())
  userId      String
  missionId   String
  
  progress    Int          @default(0)
  status      MissionStatus @default(AVAILABLE)
  
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime
  
  user        UserGamification @relation(fields: [userId], references: [userId], onDelete: Cascade)
  mission     Mission       @relation(fields: [missionId], references: [id])
  
  @@unique([userId, missionId])
  @@index([userId])
  @@index([status])
}

// =====================================================
// AUDIT & LOGGING MODELS
// =====================================================

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  resource  String
  details   String?  // JSON stringified data
  userId    String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([resource])
  @@index([createdAt])
}
